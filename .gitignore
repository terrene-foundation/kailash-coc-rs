# Runtime-installed deps (never committed) — installed at container startup, not baked.
# The repo source is bind-mounted, so a build-time install would be shadowed (journal/0005).
node_modules/
.codex-mcp-guard/node_modules/

# Secrets
*.pem
*.key
secrets/

# Docker dev environment — project-owned populated overlays (template scaffolds
# remain tracked; the populated forms below are project state and never committed).
# See workspaces/docker-dev-environment/specs/credentials-secrets.md.
compose.override.yml
*.local
# Gemfile.user.lock is project-state generated by `bin/dev setup` from Gemfile.user.
# Commented OUT by default so application-shape projects can commit it for
# reproducibility; uncomment if your project prefers floating gem versions.
# Gemfile.user.lock

# Workspace session notes (per-session, not versioned)
**/.session-notes

# Per-project learning data (generated at runtime)
.claude/learning/
.claude/rules/learned-instincts.md

# Internal docs (not for distribution)
/docs/01-kailash-vibe-cc-internals/

# Generated script outputs (sdk-users examples)
**/scripts/data/
**/scripts/outputs/
**/scripts/*.log
