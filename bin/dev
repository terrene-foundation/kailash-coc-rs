#!/usr/bin/env bash
# =============================================================================
# bin/dev — one-command entry to the Kailash COC (rs) dev environment.
#
#   ./bin/dev            bring the stack up + drop into a ready shell
#   ./bin/dev setup      (re)install runtime deps — MCP guard + project overlays
#                        (Python / Ruby / npm), no image rebuild
#   ./bin/dev <args>     pass through to `docker compose <args>`
#
# Keys come from `.env` (gitignored) — never baked into the image. Project
# overlays (`requirements-user.txt`, `Gemfile.user`, `package.json`) are
# project-owned (template `/sync` never touches them); they install into the
# SAME `/opt/venv` and `/opt/gems` the base uses (NFR-12 shared-env invariant),
# so additions are requireable in the same shell with NO rebuild.
#
# See workspaces/docker-dev-environment/specs/{container-topology,extensibility}.md.
# =============================================================================
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

compose() { docker compose "$@"; }

ensure_env() {
  if [ ! -f "$ROOT/.env" ] && [ -f "$ROOT/.env.example" ]; then
    cp "$ROOT/.env.example" "$ROOT/.env"
    echo "⚠  Created .env from .env.example — add your API keys."
    echo "   (The CLIs run, but fail at use until a key is present — no silent fallback.)"
  fi
}

# Single source of truth for in-container runtime install steps. Runs inside the
# workspace container (either via `compose exec` from the host, or directly when
# `bin/dev setup` is invoked from postCreate inside the container itself).
#   1. MCP guard deps (M1; bind-mount shadows a build-time install — journal/0005).
#   2. Python overlay → /opt/venv (NFR-12 shared env; same interpreter as base).
#   3. Ruby   overlay → /opt/gems FLAT layout (NFR-12; BUNDLE_PATH MUST be unset
#      — verified live 2026-05-28, see journal/0009).
#   4. npm    overlay → workspace node_modules (optional; runs only if package.json).
#   5. GPG    keyring → container-side ~/.gnupg from /host-gnupg side-mount (FR-25;
#      cross-platform host:Linux gpg-agent ABI gap — see compose.override.yml.example
#      "GPG commit-signing key" block + journal/0012).
read -r -d '' INSTALL_OVERLAYS_SH <<'OVERLAYS_EOF' || true
set -e
cd /workspace

# `has_content` = at least one non-blank, non-comment line (pip-style overlays).
# `has_gem_decl` = at least one `gem "..."` declaration (bundler-DSL overlays).
# The Gemfile gate is stricter so the shipped source-only scaffold does NOT
# generate a noisy empty Gemfile.user.lock on every fresh-clone `./bin/dev`.
has_content()  { [ -f "$1" ] && grep -Ev "^[[:space:]]*(#|$)" "$1" >/dev/null 2>&1; }
has_gem_decl() { [ -f "$1" ] && grep -Eq "^[[:space:]]*gem[[:space:]]+[\"\x27]" "$1"; }

if [ -d /workspace/.codex-mcp-guard ] && [ ! -d /workspace/.codex-mcp-guard/node_modules ]; then
  echo "→ Installing MCP guard deps (.codex-mcp-guard)…"
  ( cd /workspace/.codex-mcp-guard && npm ci --no-fund --no-audit )
fi

if has_content requirements-user.txt; then
  echo "→ Installing Python overlay (requirements-user.txt → /opt/venv)…"
  python -m pip install --no-cache-dir -r requirements-user.txt
fi

if has_gem_decl Gemfile.user; then
  # BUNDLE_PATH unset → bundler installs system-wide into GEM_HOME flat layout
  # (verified live 2026-05-28; setting it forces nested layout that breaks
  # plain-shell `require`, the NFR-12 peer-validated trap). BUNDLE_APP_CONFIG
  # also unset so a project-local `.bundle/config` cannot resurrect a `path`
  # setting that would re-create the trap.
  echo "→ Installing Ruby overlay (Gemfile.user → /opt/gems flat)…"
  env -u BUNDLE_PATH -u BUNDLE_APP_CONFIG \
      BUNDLE_GEMFILE=/workspace/Gemfile.user bundle install
fi

if [ -f /workspace/package.json ]; then
  # Prefer `npm ci` when a lockfile is present (reproducible, refuses on
  # mismatch); fall back to `npm install` for first-time projects that have
  # not committed a lockfile yet. Mirrors the MCP-guard install above.
  echo "→ Installing npm overlay (package.json)…"
  if [ -f /workspace/package-lock.json ]; then
    ( cd /workspace && npm ci --no-fund --no-audit )
  else
    ( cd /workspace && npm install --no-fund --no-audit )
  fi
fi

# --- GPG keyring bootstrap (FR-25) ------------------------------------------
# If the user opted into the GPG side-mount in compose.override.yml
# (`${HOME}/.gnupg:/host-gnupg:ro`), populate a fresh container-side ~/.gnupg
# with ONLY the key material — never the host's UNIX socket/lock files.
#
# Why this dance: macOS host gpg-agent uses platform-specific sockets that
# Linux gpg-agent rejects with "General error" on startup; a direct mount of
# the host's ~/.gnupg leaks those files in and breaks signing silently. The
# side-mount + selective copy crosses the macOS↔Linux gpg ABI gap cleanly:
# host keyring is read-only at /host-gnupg (no container write to host);
# Linux gpg-agent creates its sockets in the writable container-side ~/.gnupg.
#
# Idempotent: re-runs refresh `private-keys-v1.d/` + `pubring.kbx` + trustdb
# in case the user added a new key on the host between sessions.
if [ -d /host-gnupg ]; then
  echo "→ Bootstrapping GPG keyring (/host-gnupg → ~/.gnupg, sockets excluded)…"
  GNUPGHOME="${GNUPGHOME:-$HOME/.gnupg}"
  mkdir -p "$GNUPGHOME" && chmod 700 "$GNUPGHOME"
  # Selective copy: key material only — NOT S.gpg-agent*, NOT .#lk* lock files.
  [ -d /host-gnupg/private-keys-v1.d ] && cp -r /host-gnupg/private-keys-v1.d "$GNUPGHOME/" 2>/dev/null || true
  [ -f /host-gnupg/pubring.kbx ]       && cp    /host-gnupg/pubring.kbx       "$GNUPGHOME/" 2>/dev/null || true
  [ -f /host-gnupg/trustdb.gpg ]       && cp    /host-gnupg/trustdb.gpg       "$GNUPGHOME/" 2>/dev/null || true
  [ -f /host-gnupg/gpg.conf ]          && cp    /host-gnupg/gpg.conf          "$GNUPGHOME/" 2>/dev/null || true
  chmod -R go-rwx "$GNUPGHOME"
  [ -d "$GNUPGHOME/private-keys-v1.d" ] && chmod 700 "$GNUPGHOME/private-keys-v1.d"
fi
OVERLAYS_EOF

setup_in_container() {
  compose exec -T workspace bash -lc "$INSTALL_OVERLAYS_SH"
}

case "${1:-up}" in
  setup)
    # Used by devcontainer postCreateCommand (runs already inside the container)
    # AND callable from the host (execs into the running container).
    if [ -f /.dockerenv ]; then
      bash -lc "$INSTALL_OVERLAYS_SH"
    else
      compose up -d
      setup_in_container
    fi
    ;;
  up | "")
    ensure_env
    compose up -d
    setup_in_container
    echo "✓ Stack up. Entering workspace shell (exit to leave; stack keeps running)."
    compose exec workspace bash
    ;;
  *)
    compose "$@"
    ;;
esac
